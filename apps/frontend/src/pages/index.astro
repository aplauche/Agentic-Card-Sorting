---
import Layout from '../layouts/Layout.astro';
import SortForm from '../components/SortForm.tsx';
---

<Layout title="Card Sort — Open Card Sort with AI Agents">
  <a href="/" class="brand">Agentic Open Card Sorting</a>

  <section class="hero">
    <p class="eyebrow">Information architecture · Hierarchical cluster analysis</p>
    <h1 class="hero-title">Rapid Testing <br />and Iteration.</h1>
    <p class="hero-sub">Run open card sorts with 20 agentic participants and rapidly generate potential trees for further validation.</p>
  </section>

  <SortForm client:load />
</Layout>

<style>
  .brand { margin-bottom: 3.5rem; }
  .hero { padding: 0 0 1rem; margin-bottom: 2.5rem; }
  .hero-title {
    font-size: clamp(2.6rem, 7vw, 4.75rem);
    margin: 1.25rem 0 1.5rem;
  }
  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 620px;
  }
</style>
